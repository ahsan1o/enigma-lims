# Kotli LIMS Environment Configuration
# Copy this to .env and customize for your environment

# ============================================================================
# BACKEND SETTINGS
# ============================================================================

# Database
DATABASE_URL=sqlite:///./data/kotli_lims.db
DATABASE_ECHO=false

# Server
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
SERVER_RELOAD=true

# Security (CHANGE THESE IN PRODUCTION!)
SECRET_KEY=kotli-lims-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ============================================================================
# FRONTEND SETTINGS
# ============================================================================

# API Connection
API_URL=http://127.0.0.1:8000
API_TIMEOUT=30

# Application
APP_NAME=Kotli LIMS
APP_VERSION=1.0.0
ORGANIZATION=LocalMarketSoftwares

# UI/UX
THEME=dark
FONT_SIZE=12
AUTO_LOGOUT=true
SESSION_TIMEOUT=1800

# ============================================================================
# LAB CONFIGURATION
# ============================================================================

# Lab Identity
LAB_NAME=Kotli Clinical Lab
LAB_CODE=KCL
LAB_ADDRESS=Kotli, Pakistan
LAB_PHONE=+92-XXX-XXXXXXX
LAB_EMAIL=lab@kotli.pk

# Operating Hours
LAB_OPEN_TIME=08:00
LAB_CLOSE_TIME=18:00

# ============================================================================
# MACHINE INTEGRATION
# ============================================================================

# Machine Connection Settings
MACHINE_IP=192.168.1.100
MACHINE_PORT=9000
MACHINE_CONNECTION_TYPE=tcp  # tcp, usb, file

# ============================================================================
# BACKUP & SYNC
# ============================================================================

# Offline Sync
AUTO_BACKUP=true
BACKUP_INTERVAL=3600  # seconds (1 hour)
BACKUP_PATH=./data/backups

# Cloud Sync (Optional)
ENABLE_CLOUD_SYNC=false
CLOUD_SERVER_URL=https://api.kotli-lims.com
CLOUD_API_KEY=your-api-key-here

# ============================================================================
# LOGGING
# ============================================================================

LOG_LEVEL=INFO
LOG_FILE=./logs/kotli_lims.log
LOG_ROTATION=daily

# ============================================================================
# COMPLIANCE & SECURITY
# ============================================================================

# Data Encryption
ENCRYPT_SENSITIVE_DATA=true
ENCRYPTION_KEY=change-this-key-in-production

# Audit Logging
ENABLE_AUDIT_LOG=true
AUDIT_LOG_RETENTION_DAYS=365

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Debug Mode
DEBUG=false
VERBOSE=false

# API Documentation
SHOW_DOCS=true  # /api/docs endpoint

# Testing
TEST_MODE=false
USE_MOCK_DATA=false
